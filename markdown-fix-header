#!/bin/bash

SCRIPT_NAME="$(basename "$(test -L "$0" && readlink "$0" || echo "$0")")"
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null 2>&1 && pwd )"

function echoerr {
  printf "%s\n" "$*" >&2;
}

function help_exit { EXIT_CODE="$1";
  if [[ -z "$EXIT_CODE" ]]; then
    EXIT_CODE=1
  fi

  echoerr "Usage: ${SCRIPT_NAME} [-c|--clipboard] [-f|--force]"
  echoerr "Env variables: YT_PROXY_PORT"
  exit "$EXIT_CODE"
}

function output_to_clipboard {
  local CONTENT="$1"
  if [[ "$CLIPBOARD_MODE" -eq 1 ]]; then
    echo "$CONTENT" | xclip -selection c
    echoerr ""
    echoerr "- copied to clipboard"
  fi
}

CLIPBOARD_MODE=
FORCE_MODE=

while [[ $# -gt 0 ]]; do
    OPTION="$1"

    case "$OPTION" in
        -c|--clipboard)
            CLIPBOARD_MODE=1
        ;;
        -f|--force)
            FORCE_MODE=1
        ;;
        -h|--help)
            help_exit
        ;;
        *)
          if [[ "${OPTION:0:1}" == "-" ]]; then
            echoerr "Error: unknown option \"$OPTION\""
            help_exit
          else
            break
          fi
        ;;
    esac
    shift
done

if [[ "$CLIPBOARD_MODE" -eq 1 ]]; then
  INPUT=$(xclip -selection c -o)
else
  if [ ! -t 0 ]; then
    INPUT=$(< /dev/stdin)
  else
    help_exit 1
  fi
fi

# Regex patterns for URL matching
REGEX_PROTOCOL='https?://'
REGEX_HOSTNAME='[a-zA-Z0-9][-a-zA-Z0-9]*'
REGEX_DOMAIN='\.[a-zA-Z]{2,}'
REGEX_PATH='[^[:space:]]*'
REGEX_URL="(${REGEX_PROTOCOL})?${REGEX_HOSTNAME}${REGEX_DOMAIN}${REGEX_PATH}"

# Find URL in first two lines using for loop
URL=
URL_LINE_NUM=

for LINE_NUM in 1 2; do
  LINE=$(echo "$INPUT" | sed -n "${LINE_NUM}p")
  # Extract URL from line (with or without protocol)
  EXTRACTED_URL=$(echo "$LINE" | grep -oE "$REGEX_URL" | head -1)
  if [[ -n "$EXTRACTED_URL" ]]; then
    URL="$EXTRACTED_URL"
    URL_LINE_NUM=$LINE_NUM
    break
  fi
done

if [[ -z "$URL" ]]; then
  if [[ -n "$FORCE_MODE" ]]; then
    echoerr "Warning: no URL found in first two lines. Forcing the header"
    # Capitalize first letter and add '# ' prefix to first line only
    FIRST_LINE=$(echo "$INPUT" | sed -n '1p')
    # Use sed to capitalize first character (works with UTF-8)
    NEW_FIRST_LINE=$(echo "$FIRST_LINE" | sed 's/^\(.\)/\U\1/')
    NEW_FIRST_LINE="# ${NEW_FIRST_LINE}"
    # Output modified first line and rest of input
    echo "$NEW_FIRST_LINE"
    echo "$INPUT" | tail -n +2
    OUTPUT=$(printf "%s\n%s" "$NEW_FIRST_LINE" "$(echo "$INPUT" | tail -n +2)")
    output_to_clipboard "$OUTPUT"
    exit
  else
    echoerr "Error: no URL found in first two lines"
    exit 100
  fi
fi

# If URL is on second line, remove first line
if [[ "$URL_LINE_NUM" -eq 2 ]]; then
  REMAINING_INPUT=$(echo "$INPUT" | tail -n +2)
else
  REMAINING_INPUT="$INPUT"
fi

PROCESSOR_ARGS=()

# Choose processor based on URL
if echo "$URL" | grep -qE 'youtu\.be|youtube\.com'; then
  PROCESSOR="markdown-header-from-youtube"
  if [[ -n "$YT_PROXY_PORT" ]]; then
    PROCESSOR_ARGS=(--proxy "socks5://127.0.0.1:$YT_PROXY_PORT")
  fi
else
  PROCESSOR="markdown-header-from-url"
fi

# Run processor
RESULT=$($SCRIPT_DIR/$PROCESSOR "${PROCESSOR_ARGS[@]}" "$URL")

if [[ $? -ne 0 ]]; then
  echoerr "Error: $PROCESSOR failed"
  exit 200
fi

# Check if ripgrep is available
if ! command -v rg &> /dev/null; then
  echoerr "Error: ripgrep (rg) is not installed. See https://github.com/burntsushi/ripgrep"
  exit 300
fi

# Replace original URL with result using ripgrep
FINAL_OUTPUT=$(echo -e "$REMAINING_INPUT" | rg --fixed-strings --no-line-number --passthru --replace "$RESULT" "$URL")

echoerr "=== Fix header result: ==="
echoerr
echo "$FINAL_OUTPUT"
output_to_clipboard "$FINAL_OUTPUT"
