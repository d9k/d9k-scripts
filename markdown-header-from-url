#!/bin/bash

SCRIPT_NAME="$(basename "$(test -L "$0" && readlink "$0" || echo "$0")")"
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null 2>&1 && pwd )"
TEMP_DIR="/tmp/$SCRIPT_NAME"

function echoerr {
  # printf "%s\n" "$*" >&2;
  # %b interprets escape-sequences
  printf "%b\n" "$*" >&2
}

function help_exit { EXIT_CODE="$1";
  if [[ -z "$EXIT_CODE" ]]; then
    EXIT_CODE=1
  fi

  echoerr "Usage: ${SCRIPT_NAME} [-c|--copy-to-clipboard] [--link] URL"
  exit "$EXIT_CODE"
}

COPY_TO_CLIPBOARD=
LINK_MODE=

while [[ $# -gt 0 ]]; do
    OPTION="$1"

    case "$OPTION" in
        -c|--copy-to-clipboard)
            COPY_TO_CLIPBOARD=1
        ;;
        --link)
            LINK_MODE=1
        ;;
        -h|--help)
            help_exit
        ;;
        *)
          if [[ "${OPTION:0:1}" == "-" ]]; then
            echoerr "Error: unknown option \"$OPTION\""
            help_exit
          else
            break
          fi
        ;;
    esac
    shift
done

# Arguments count check
if [ "$#" -lt 1 ]; then
  help_exit 1
fi

URL="$1"

# Add https:// prefix if URL doesn't start with a protocol
if [[ ! "$URL" =~ ^[a-zA-Z]+:// ]]; then
  URL="https://$URL"
fi

# Create metadata file names from URL (remove protocol, #, ? and everything after, then trailing slash)
URL_BASENAME=$(echo "$URL" | sed 's|[?#].*||')
URL_BASENAME_NO_PROTOCOL=$(echo "$URL_BASENAME" | sed 's|^https\?://||' | sed 's|/$||')
# Extract domain from URL
DOMAIN=$(echo "$URL_BASENAME_NO_PROTOCOL" | sed 's|/.*||')
METADATA_FILE_NAME=$(echo "$URL_BASENAME_NO_PROTOCOL" | sed 's/[^[:alpha:].-]/_/g')
METADATA_FILE_NAME=$(echo "$URL_BASENAME" | sed 's/[^[:alpha:].-]/_/g')
METADATA_FILE_NAME_MD="${METADATA_FILE_NAME}.md"
METADATA_FILE_NAME_JS="${METADATA_FILE_NAME}.js"

mkdir -p "$TEMP_DIR"
cd "$TEMP_DIR"

# Check if frontmatter is installed
if ! command -v frontmatter &> /dev/null; then
  echoerr "Error: frontmatter is not installed."
  echoerr "Download from: https://github.com/rythoris/frontmatter"
  exit 100
fi

# Fetch metadata using url-metadata
echoerr "Fetching metadata from: $URL"
url-metadata "$URL" > "$METADATA_FILE_NAME_MD" 2>/dev/null

if [ $? -ne 0 ] || [ ! -s "$METADATA_FILE_NAME_MD" ]; then
  echoerr "Error: failed to fetch metadata from URL"
  exit 200
fi

# Convert markdown to JSON using frontmatter
frontmatter "$METADATA_FILE_NAME_MD" > "$METADATA_FILE_NAME_JS" 2>/dev/null

if [ $? -ne 0 ] || [ ! -s "$METADATA_FILE_NAME_JS" ]; then
  echoerr "Error: failed to convert metadata to JSON"
  exit 300
fi

METADATA_JS=$(cat "$METADATA_FILE_NAME_JS" | jq)

echoerr "$METADATA_JS\n"

# Extract data from JSON using jq
TITLE=$(echo -e "$METADATA_JS" | jq --raw-output '.title // empty')
AUTHOR=$(echo -e "$METADATA_JS" | jq --raw-output '.author // empty')

SITE=$(echo -e "$METADATA_JS" | jq --raw-output '.site // empty')
if [[ -z "$SITE" ]]; then
  SITE="$DOMAIN"
fi
SITE=$(printf "%s" "$SITE" | sed 's|www.||')

DATE=$(echo -e "$METADATA_JS" | jq --raw-output '.date // empty')

if [ -n "$DATE" ]; then
  YEAR=$(echo "$DATE" | cut -c 1-4)
else
  YEAR=""
fi

YEAR_TEXT=""
if [[ -n "$YEAR" ]]; then
  YEAR_TEXT=", $YEAR"
fi

LINK_TITLE="$TITLE"
if [[ -n "$AUTHOR" ]]; then
  LINK_TITLE="$LINK_TITLE / $AUTHOR"
fi
LINK_TITLE="$LINK_TITLE / $SITE"

if [[ -n $LINK_MODE ]]; then
  RESULT="- [${LINK_TITLE}](${URL_BASENAME})${YEAR_TEXT}"
else
  RESULT="# ${LINK_TITLE}${YEAR_TEXT}\n\n${URL_BASENAME}"
fi

# printf '%s' -- "$RESULT"
echo -n -e "$RESULT"

if [[ -n "$COPY_TO_CLIPBOARD" ]]; then
  echo -n -e "$RESULT" | xclip -selection c
  echoerr ""
  echoerr "- copied to clipboard"
fi
