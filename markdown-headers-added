#!/usr/bin/env bash

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null 2>&1 && pwd )"
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null)
SCRIPT_NAME="$(basename "$(test -L "$0" && readlink "$0" || echo "$0")")"
S="$HOME/scripts"

SHORT_MODE=
FILE_NAME=""

function echoerr {
  printf "%s\n" "$*" >&2;
}

function help_exit { EXIT_CODE="$1";
  if [[ -z "$EXIT_CODE" ]]; then
    EXIT_CODE=1
  fi

  echoerr "Usage: $SCRIPT_NAME [-s|--short] [FILE_NAME]"
  exit $EXIT_CODE
}

# Format header: remove leading '#', '/', trim whitespace
function format_short_header {
  echo "$1" | sed 's/^#* *//' | sed 's/ *\/.*$//' | sed 's/, *[0-9]\{4\}.*$//' | sed 's/^ *//' | sed 's/ *$//'
}

# Process added headers for a single file
function process_file {
  local FILE_ARG="$1"
  local DIFF_OUTPUT
  git reset >/dev/null
  git add "$FILE_ARG"
  # DIFF_OUTPUT=$(git --no-pager diff -- "$FILE_ARG" | grep "^+#" | sed 's/^+//')
  DIFF_OUTPUT=$(git --no-pager diff --cached | grep "^+#" | sed 's/^+//')
  git reset >/dev/null

  if [[ -z "$DIFF_OUTPUT" ]]; then
    return
  fi

  if [[ -n $SHORT_MODE ]]; then
    echo "$DIFF_OUTPUT" | while IFS= read -r line; do
      format_short_header "$line"
    done
  else
    echo "$DIFF_OUTPUT"
  fi
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -s|--short)
      SHORT_MODE=1
      shift
      ;;
    -h|--help)
      help_exit 0
      ;;
    -*)
      echoerr "Unknown option: $1"
      help_exit 100
      ;;
    *)
      if [[ -z "$FILE_NAME" ]]; then
        FILE_NAME="$1"
      else
        echoerr "Too many arguments"
        help_exit 110
      fi
      shift
      ;;
  esac
done

if [[ -n "$FILE_NAME" ]]; then
  process_file "$FILE_NAME"
else
  # Process all changed files (exclude deleted files starting with " D")
  cd "$REPO_ROOT"
  git status --porcelain | grep -v "^ D" | while IFS= read -r line; do
    # Cut first 3 chars (status flags) to get file name
    FILE_ARG=$(echo "$line" | cut -c4-)
    FILE_RESULT=$(process_file "$FILE_ARG")
    if [[ -n "$FILE_RESULT" ]]; then
      echo
      echo "=== $FILE_ARG ==="
      echo "$FILE_RESULT"
    fi
  done
fi
